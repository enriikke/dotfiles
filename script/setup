#!/usr/bin/env bash
#
# Bootstrap script for dotfiles
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/enriikke/dotfiles/main/script/setup | bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() { printf "${GREEN}[INFO]${NC} %s\n" "$1"; }
warn() { printf "${YELLOW}[WARN]${NC} %s\n" "$1"; }
error() { printf "${RED}[ERROR]${NC} %s\n" "$1"; }

detect_platform() {
  local os arch
  case "$(uname -s)" in
    Darwin) os="darwin" ;;
    Linux)  os="linux" ;;
    *)      error "Unsupported OS: $(uname -s)"; exit 1 ;;
  esac
  case "$(uname -m)" in
    x86_64|amd64)  arch="amd64" ;;
    arm64|aarch64) arch="arm64" ;;
    *)             error "Unsupported architecture: $(uname -m)"; exit 1 ;;
  esac
  echo "${os}_${arch}"
}

get_latest_version() {
  curl -fsSL "https://api.github.com/repos/enriikke/dotfiles/releases/latest" | 
    grep '"tag_name"' | 
    sed -E 's/.*"([^"]+)".*/\1/'
}

install_binary() {
  local version="$1"
  local platform="$2"
  local install_dir="$HOME/.local/bin"
  local tmp_dir
  tmp_dir=$(mktemp -d)
  trap 'rm -rf "$tmp_dir"' EXIT

  local url="https://github.com/enriikke/dotfiles/releases/download/${version}/dotfiles_${version#v}_${platform}.tar.gz"
  
  info "Downloading dotfiles ${version} for ${platform}..."
  curl -fsSL "$url" -o "$tmp_dir/dotfiles.tar.gz"

  info "Extracting..."
  tar -xzf "$tmp_dir/dotfiles.tar.gz" -C "$tmp_dir"

  info "Installing to $install_dir..."
  mkdir -p "$install_dir"
  mv "$tmp_dir/dotfiles" "$install_dir/dotfiles"
  chmod +x "$install_dir/dotfiles"

  if [[ ":$PATH:" != *":$install_dir:"* ]]; then
    warn "$install_dir is not in your PATH"
    export PATH="$install_dir:$PATH"
  fi

  info "✓ dotfiles installed!"
}

find_repo() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  
  if [[ -f "$script_dir/../dotfiles.yaml" ]]; then
    echo "$(cd "$script_dir/.." && pwd)"
    return 0
  fi

  for path in "$HOME/.dotfiles" "$HOME/dotfiles"; do
    if [[ -f "$path/dotfiles.yaml" ]]; then
      echo "$path"
      return 0
    fi
  done

  return 1
}

get_clone_path() {
  local yaml path
  yaml=$(curl -fsSL "https://raw.githubusercontent.com/enriikke/dotfiles/main/dotfiles.yaml" 2>/dev/null)
  if [[ -n "$yaml" ]]; then
    path=$(echo "$yaml" | grep -A1 'repo_paths:' | tail -1 | sed 's/.*- *//' | xargs)
    if [[ -n "$path" ]]; then
      echo "${path/#\~/$HOME}"
      return 0
    fi
  fi
  echo "$HOME/.dotfiles"
}

main() {
  info "🚀 dotfiles bootstrap"
  echo

  local platform
  platform=$(detect_platform)
  info "Detected platform: $platform"

  if command -v dotfiles &>/dev/null; then
    info "dotfiles CLI already installed"
  else
    local repo_path
    if repo_path=$(find_repo); then
      if command -v go &>/dev/null; then
        info "Building from source..."
        (cd "$repo_path" && go build -o dotfiles ./cmd/dotfiles)
        export PATH="$repo_path:$PATH"
      else
        local version
        version=$(get_latest_version)
        if [[ -z "$version" ]]; then
          error "Could not determine latest version. Install Go and build from source."
          exit 1
        fi
        install_binary "$version" "$platform"
      fi
    else
      local version
      version=$(get_latest_version)
      if [[ -z "$version" ]]; then
        error "Could not determine latest version and no local repo found"
        exit 1
      fi
      install_binary "$version" "$platform"
    fi
  fi

  echo
  info "Running dotfiles init..."
  echo

  if ! repo_path=$(find_repo); then
    local clone_path
    clone_path=$(get_clone_path)
    info "Cloning dotfiles repository to $clone_path..."
    git clone https://github.com/enriikke/dotfiles.git "$clone_path"
    repo_path="$clone_path"
  fi

  dotfiles init --repo="$repo_path"
}

main "$@"
